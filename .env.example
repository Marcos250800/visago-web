# Copia este archivo a .env.local (no se sube al repo) y rellena los valores.
# En producción, añade las mismas variables en Vercel → Project → Settings → Environment Variables.

# Web3Forms — formulario de contacto.
# Crea una access key gratis en https://web3forms.com (te pide tu email de destino).
# La access key de Web3Forms es PÚBLICA por diseño (va en el cliente), por eso lleva el prefijo NEXT_PUBLIC_.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
